## Contact form (Vercel API + Resend)
# Frontend (React)
# Optional: recipient email for mailto fallback (default is dibalabimoussa65@gmail.com)
# REACT_APP_CONTACT_TO=
#
# Optional: override contact API URL (for local dev if needed)
# REACT_APP_CONTACT_API_URL=http://localhost:3000/api/contact
#
# Backend (Vercel Serverless Function)
# Required: Resend API key
# RESEND_API_KEY=
#
# Required: sender email address verified in Resend (e.g. contact@yourdomain.com)
# CONTACT_FROM=
#
# Optional: where to deliver messages (defaults to dibalabimoussa65@gmail.com)
# CONTACT_TO=
